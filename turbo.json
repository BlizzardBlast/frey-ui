{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["biome.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!**/*.test.*",
        "!**/*.spec.*"
      ],
      "outputs": ["dist/**", "storybook-static/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": ["node_modules/.tmp/tsconfig.tsbuildinfo"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
