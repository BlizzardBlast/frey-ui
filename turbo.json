{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["biome.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!**/.continue/**",
        "!**/.cursor/**",
        "!**/.gemini/**",
        "!**/.mcp.json",
        "!**/opencode.json",
        "!**/*.test.*",
        "!**/*.spec.*"
      ],
      "outputs": ["dist/**", "storybook-static/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!**/.continue/**",
        "!**/.cursor/**",
        "!**/.gemini/**",
        "!**/.mcp.json",
        "!**/opencode.json"
      ],
      "outputs": ["node_modules/.tmp/tsconfig.tsbuildinfo"]
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!**/.continue/**",
        "!**/.cursor/**",
        "!**/.gemini/**",
        "!**/.mcp.json",
        "!**/opencode.json"
      ],
      "outputs": []
    },
    "test": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!**/.continue/**",
        "!**/.cursor/**",
        "!**/.gemini/**",
        "!**/.mcp.json",
        "!**/opencode.json"
      ],
      "outputs": []
    },
    "//#docs:check": {
      "inputs": [
        "apps/storybook/src/stories/**",
        "packages/frey-ui/src/index.ts",
        "scripts/check-storybook-api-coverage.mjs",
        "scripts/storybookDocsCheck.mjs"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
