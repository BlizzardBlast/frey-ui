{
  "name": "frey-ui-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:storybook": "turbo run build-storybook --filter=@frey-ui/storybook",
    "dev": "turbo run dev --filter=@frey-ui/storybook",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:staged": "biome check --write --staged --no-errors-on-unmatched",
    "check:changed": "biome ci --changed --since=origin/main --no-errors-on-unmatched .",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=@frey-ui/playwright",
    "test:coverage": "turbo run test:coverage --filter=frey-ui",
    "playwright:install": "pnpm --filter @frey-ui/playwright exec playwright install chromium",
    "theme:tokens": "node scripts/generate-theme-tokens.mjs",
    "docs:check": "node scripts/check-storybook-api-coverage.mjs",
    "storybook": "turbo run storybook --filter=@frey-ui/storybook",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "ci:changed": "turbo run lint typecheck test build --affected",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "turbo": "^2.9.3",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "valibot": "^1.3.0"
    }
  }
}
