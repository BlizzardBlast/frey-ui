  },
  decorators: [
    withThemeByDataAttribute({
      themes: {
        light: 'light',
        dark: 'dark'
      },
      defaultTheme: 'light',
      attributeName: 'data-theme'
    }),
    (Story) => (
      <div className='frey-theme-provider'>
        <Story />
      </div>
    )
  ],
  tags: ['autodocs']
};

export default preview;
