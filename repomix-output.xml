    render(<Chip as='span' label='Space chip' onClick={onClick} />);

    const chip = screen.getByRole('button', { name: 'Space chip' });
    chip.focus();
    await user.keyboard(' ');

    expect(onClick).toHaveBeenCalledTimes(1);
