<file path="scripts/check-storybook-api-coverage.mjs">
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const rootDir = path.resolve(__dirname, '..');

const libraryIndexPath = path.join(
  rootDir,
  'packages',
  'frey-ui',
  'src',
  'index.ts'
);
const storiesRoot = path.join(rootDir, 'apps', 'storybook', 'src', 'stories');

function walkStoryFiles(dir) {
  const storyFiles = [];
  const entries = fs.readdirSync(dir, { withFileTypes: true });

  for (const entry of entries) {
    const entryPath = path.join(dir, entry.name);
    if (entry.isDirectory()) {
      storyFiles.push(...walkStoryFiles(entryPath));
      continue;
    }
    if (entry.isFile() && entry.name.endsWith('.stories.tsx')) {
      storyFiles.push(entryPath);
    }
  }

  return storyFiles;
}

const indexSource = fs.readFileSync(libraryIndexPath, 'utf8');
const exportMatches = [
  ...indexSource.matchAll(
    /export\s+\{\s*default\s+as\s+(\w+)\s*\}\s+from\s+'\.\/[^']+';/g
  )
];

const exportedComponents = exportMatches
  .map((match) => match[1])
  .sort((a, b) => a.localeCompare(b));

const storyFiles = walkStoryFiles(storiesRoot);
const documentedComponents = new Set(
  storyFiles
    .map(
      (storyPath) => path.relative(storiesRoot, storyPath).split(path.sep)[0]
    )
    .filter(Boolean)
);

const missingStories = exportedComponents.filter(
  (componentName) => !documentedComponents.has(componentName)
);

const castWrapperStoryFiles = storyFiles
  .filter((storyPath) => {
    const source = fs.readFileSync(storyPath, 'utf8');
    return /as unknown as React\.ComponentType/.test(source);
  })
  .map((storyPath) => path.relative(rootDir, storyPath));

if (missingStories.length > 0 || castWrapperStoryFiles.length > 0) {
  console.error('Storybook API coverage check failed.');

  if (missingStories.length > 0) {
    console.error('\nMissing component stories:');
    for (const componentName of missingStories) {
      console.error(`- ${componentName}`);
    }
  }

  if (castWrapperStoryFiles.length > 0) {
    console.error('\nStories still using cast wrappers:');
    for (const storyPath of castWrapperStoryFiles) {
      console.error(`- ${storyPath}`);
    }
  }

  process.exit(1);
}

console.log(
  `Storybook API coverage check passed for ${exportedComponents.length} component exports.`
);
</file>

<file path="scripts/generate-theme-tokens.mjs">
const DEFAULT_COLORS = {
  neutral: '#6b7280',
  success: '#16a34a',
  warning: '#d97706',
  error: '#dc2626',
  info: '#2563eb'
};

const SUPPORTED_FLAGS = new Set([
  '--primary',
  '--neutral',
  '--success',
  '--warning',
  '--error',
  '--info',
  '--help'
]);

function writeError(message) {
  process.stderr.write(`${message}\n`);
}

function normalizeHex(value, flagName) {
  if (typeof value !== 'string') {
    throw new Error(`Missing color value for ${flagName}.`);
  }

  const trimmed = value.trim();
  const match = /^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/.exec(trimmed);

  if (!match) {
    throw new Error(`Invalid hex color for ${flagName}: "${value}".`);
  }

  const raw = match[1].toLowerCase();

  if (raw.length === 3) {
    return `#${raw
      .split('')
      .map((character) => `${character}${character}`)
      .join('')}`;
  }

  return `#${raw}`;
}

function hexToRgb(hex) {
  const value = hex.slice(1);
  return {
    red: Number.parseInt(value.slice(0, 2), 16),
    green: Number.parseInt(value.slice(2, 4), 16),
    blue: Number.parseInt(value.slice(4, 6), 16)
  };
}

function rgbToHex({ red, green, blue }) {
  const toHex = (channel) => {
    return Math.round(Math.max(0, Math.min(255, channel)))
      .toString(16)
      .padStart(2, '0');
  };

  return `#${toHex(red)}${toHex(green)}${toHex(blue)}`;
}

function mix(baseHex, targetHex, targetWeight) {
  const clampedWeight = Math.max(0, Math.min(1, targetWeight));
  const base = hexToRgb(baseHex);
  const target = hexToRgb(targetHex);

  return rgbToHex({
    red: base.red * (1 - clampedWeight) + target.red * clampedWeight,
    green: base.green * (1 - clampedWeight) + target.green * clampedWeight,
    blue: base.blue * (1 - clampedWeight) + target.blue * clampedWeight
  });
}

function lighten(hex, amount) {
  return mix(hex, '#ffffff', amount);
}

function darken(hex, amount) {
  return mix(hex, '#000000', amount);
}

function parseArguments(argv) {
  const parsed = {};

  for (let index = 0; index < argv.length; index += 1) {
    const flag = argv[index];

    if (!SUPPORTED_FLAGS.has(flag)) {
      throw new Error(`Unknown flag "${flag}". Run with --help for usage.`);
    }

    if (flag === '--help') {
      parsed.help = true;
      continue;
    }

    const value = argv[index + 1];

    if (!value || value.startsWith('--')) {
      throw new Error(`Missing value for ${flag}.`);
    }

    parsed[flag.replace(/^--/, '')] = value;
    index += 1;
  }

  return parsed;
}

function statusTokens(color) {
  return {
    base: color,
    lightBackground: lighten(color, 0.9),
    lightBorder: lighten(color, 0.65),
    darkForeground: lighten(color, 0.2),
    darkBackground: darken(color, 0.78),
    darkBorder: darken(color, 0.5),
    highContrastLight: darken(color, 0.22),
    highContrastDark: lighten(color, 0.25)
  };
}

function buildCss(colors) {
  const primary = colors.primary;
  const neutral = colors.neutral;

  const success = statusTokens(colors.success);
  const warning = statusTokens(colors.warning);
  const error = statusTokens(colors.error);
  const info = statusTokens(colors.info);

  const lightPrimaryHover = darken(primary, 0.14);
  const lightPrimarySoft = lighten(primary, 0.88);
  const darkPrimary = lighten(primary, 0.08);
  const darkPrimaryHover = lighten(primary, 0.18);
  const darkPrimarySoft = darken(primary, 0.55);

  return `/* Generated by scripts/generate-theme-tokens.mjs */
.frey-theme-provider[data-frey-theme='light'] {
  --frey-color-primary: ${primary};
  --frey-color-focus-ring: ${primary};
  --frey-color-text-secondary: ${neutral};
  --frey-color-border: ${lighten(neutral, 0.46)};
  --frey-color-border-muted: ${lighten(neutral, 0.28)};

  --frey-switch-track-active: ${primary};
  --frey-switch-track-inactive: ${lighten(primary, 0.72)};
  --frey-focus-ring: ${primary};

  --frey-button-primary-bg: ${primary};
  --frey-button-primary-hover: ${lightPrimaryHover};
  --frey-button-secondary-border: ${primary};
  --frey-button-secondary-text: ${primary};
  --frey-button-secondary-hover-bg: ${lightPrimarySoft};
  --frey-button-ghost-text: ${primary};
  --frey-button-ghost-hover-bg: ${lightPrimarySoft};

  --frey-checkbox-checked-bg: ${primary};
  --frey-checkbox-checked-border: ${primary};

  --frey-color-success: ${success.base};
  --frey-color-success-bg: ${success.lightBackground};
  --frey-color-success-border: ${success.lightBorder};
  --frey-color-warning: ${warning.base};
  --frey-color-warning-bg: ${warning.lightBackground};
  --frey-color-warning-border: ${warning.lightBorder};
  --frey-color-error: ${error.base};
  --frey-color-error-bg: ${error.lightBackground};
  --frey-color-error-border: ${error.lightBorder};
  --frey-color-info: ${info.base};
  --frey-color-info-bg: ${info.lightBackground};
  --frey-color-info-border: ${info.lightBorder};
}

.frey-theme-provider[data-frey-theme='dark'] {
  --frey-color-primary: ${darkPrimary};
  --frey-color-focus-ring: ${darkPrimary};
  --frey-color-text-secondary: ${lighten(neutral, 0.14)};
  --frey-color-border: ${darken(neutral, 0.3)};
  --frey-color-border-muted: ${darken(neutral, 0.18)};

  --frey-switch-track-active: ${darkPrimary};
  --frey-switch-track-inactive: ${darkPrimarySoft};
  --frey-focus-ring: ${darkPrimary};

  --frey-button-primary-bg: ${darkPrimary};
  --frey-button-primary-hover: ${darkPrimaryHover};
  --frey-button-secondary-border: ${darkPrimary};
  --frey-button-secondary-text: ${darkPrimary};
  --frey-button-secondary-hover-bg: ${darkPrimarySoft};
  --frey-button-ghost-text: ${darkPrimary};
  --frey-button-ghost-hover-bg: ${darkPrimarySoft};

  --frey-checkbox-checked-bg: ${darkPrimary};
  --frey-checkbox-checked-border: ${darkPrimary};

  --frey-color-success: ${success.base};
  --frey-color-success-bg: ${success.darkBackground};
  --frey-color-success-border: ${success.darkBorder};
  --frey-color-warning: ${warning.base};
  --frey-color-warning-bg: ${warning.darkBackground};
  --frey-color-warning-border: ${warning.darkBorder};
  --frey-color-error: ${error.base};
  --frey-color-error-bg: ${error.darkBackground};
  --frey-color-error-border: ${error.darkBorder};
  --frey-color-info: ${info.base};
  --frey-color-info-bg: ${info.darkBackground};
  --frey-color-info-border: ${info.darkBorder};
}

.frey-theme-provider[data-frey-theme='light'][data-frey-high-contrast='true'] {
  --frey-button-primary-bg: ${darken(primary, 0.2)};
  --frey-button-primary-hover: ${darken(primary, 0.34)};
  --frey-button-secondary-border: ${darken(primary, 0.2)};
  --frey-button-secondary-text: ${darken(primary, 0.2)};
  --frey-button-ghost-text: ${darken(primary, 0.2)};

  --frey-color-success: ${success.highContrastLight};
  --frey-color-warning: ${warning.highContrastLight};
  --frey-color-error: ${error.highContrastLight};
  --frey-color-info: ${info.highContrastLight};
}

.frey-theme-provider[data-frey-theme='dark'][data-frey-high-contrast='true'] {
  --frey-button-primary-bg: ${lighten(primary, 0.24)};
  --frey-button-primary-hover: ${lighten(primary, 0.34)};
  --frey-button-secondary-border: ${lighten(primary, 0.24)};
  --frey-button-secondary-text: ${lighten(primary, 0.24)};
  --frey-button-ghost-text: ${lighten(primary, 0.24)};

  --frey-color-success: ${success.highContrastDark};
  --frey-color-warning: ${warning.highContrastDark};
  --frey-color-error: ${error.highContrastDark};
  --frey-color-info: ${info.highContrastDark};
}
`;
}

function printHelp() {
  process.stdout.write(`Usage:
  pnpm theme:tokens -- --primary <hex> [--neutral <hex>] [--success <hex>] [--warning <hex>] [--error <hex>] [--info <hex>]
`);
}

function main() {
  try {
    const parsed = parseArguments(process.argv.slice(2));

    if (parsed.help) {
      printHelp();
      return;
    }

    if (!parsed.primary) {
      throw new Error('Missing required --primary <hex> argument.');
    }

    const colors = {
      primary: normalizeHex(parsed.primary, '--primary'),
      neutral: normalizeHex(
        parsed.neutral ?? DEFAULT_COLORS.neutral,
        '--neutral'
      ),
      success: normalizeHex(
        parsed.success ?? DEFAULT_COLORS.success,
        '--success'
      ),
      warning: normalizeHex(
        parsed.warning ?? DEFAULT_COLORS.warning,
        '--warning'
      ),
      error: normalizeHex(parsed.error ?? DEFAULT_COLORS.error, '--error'),
      info: normalizeHex(parsed.info ?? DEFAULT_COLORS.info, '--info')
    };

    process.stdout.write(buildCss(colors));
  } catch (error) {
    writeError(error instanceof Error ? error.message : 'Unknown error.');
    process.exitCode = 1;
  }
}

main();
</file>

