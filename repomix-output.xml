  md: styles.select_md,
  lg: styles.select_lg
};

const Select: SelectComponent = React.forwardRef<
  HTMLSelectElement,
  Readonly<SelectProps>
>(function Select(
  {
    label,
    hideLabel = false,
    error,
    helperText,
    placeholder,
