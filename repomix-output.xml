<file path=".github/workflows/publish.yml">
name: Release

on:
  push:
    branches:
      - main
  workflow_dispatch:

permissions:
  contents: write
  pull-requests: write
  id-token: write

jobs:
  release:
    runs-on: ubuntu-latest
    env:
      TURBO_TOKEN: ${{ secrets.TURBO_TOKEN }}
      TURBO_TEAM: ${{ vars.TURBO_TEAM }}
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6
        with:
          fetch-depth: 0
      - uses: pnpm/action-setup@41ff72655975bd51cab0327fa583b6e92b6d3061 # v4
        with:
          version: "10.30.2"
      - uses: actions/setup-node@6044e13b5dc448c55e2357c09f80417699197238 # v6
        with:
          node-version: 22.22.0
          registry-url: "https://registry.npmjs.org"
          cache: "pnpm"
      - run: pnpm install --frozen-lockfile
      - run: pnpm turbo run build --filter=frey-ui
      - uses: changesets/action@6a0a831ff30acef54f2c6aa1cbbc1096b066edaf #v1.7.0
        with:
          version: pnpm version-packages
          publish: pnpm release
          commit: "chore: version packages"
          title: "chore: version packages"
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          NODE_AUTH_TOKEN: ${{ secrets.NPM_TOKEN }}
</file>

<file path=".github/workflows/deploy-github-pages.yml">
name: Build and Publish Storybook to GitHub Pages

on:
  push:
    branches:
      - "main"

permissions:
  contents: read
  pages: write
  id-token: write

jobs:
  deploy:
    runs-on: ubuntu-latest
    env:
      TURBO_TOKEN: ${{ secrets.TURBO_TOKEN }}
      TURBO_TEAM: ${{ vars.TURBO_TEAM }}

    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6
        with:
          fetch-depth: 0

      - uses: pnpm/action-setup@41ff72655975bd51cab0327fa583b6e92b6d3061 # v4
        with:
          version: "10.30.2"

      - uses: actions/setup-node@6044e13b5dc448c55e2357c09f80417699197238 # v6
        with:
          node-version: 22.22.0
          cache: "pnpm"
      - name: Check if Storybook is affected
        id: affected
        run: |
          set +e
          pnpm dlx turbo-ignore --task=build-storybook @frey-ui/storybook
          CODE=$?
          if [ "$CODE" -eq 1 ]; then
            echo "storybook_affected=true" >> "$GITHUB_OUTPUT"
          elif [ "$CODE" -eq 0 ]; then
            echo "storybook_affected=false" >> "$GITHUB_OUTPUT"
          else
            echo "Unexpected turbo-ignore exit code: $CODE"
            exit "$CODE"
          fi
      - name: Skip deploy (unaffected)
        if: steps.affected.outputs.storybook_affected == 'false'
        run: echo "No Storybook changes detected. Skipping GitHub Pages deploy."
      - uses: bitovi/github-actions-storybook-to-github-pages@ddd9d35f670cceedd2bfc444be681001b0709730 # v1.0.4
        if: steps.affected.outputs.storybook_affected == 'true'
        with:
          install_command: pnpm install --frozen-lockfile
          build_command: pnpm turbo run build-storybook --filter=@frey-ui/storybook
          path: apps/storybook/storybook-static
          checkout: false
</file>

<file path=".github/workflows/chromatic.yml">
name: "Chromatic Publish"

on:
  push:
    branches:
      - main
    paths:
      - "apps/storybook/**"
      - "packages/frey-ui/**"
      - "pnpm-lock.yaml"
      - "turbo.json"
      - ".github/workflows/chromatic.yml"

jobs:
  test:
    runs-on: ubuntu-latest
    env:
      TURBO_TOKEN: ${{ secrets.TURBO_TOKEN }}
      TURBO_TEAM: ${{ vars.TURBO_TEAM }}
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6
        with:
          fetch-depth: 0
      - uses: pnpm/action-setup@41ff72655975bd51cab0327fa583b6e92b6d3061 # v4
        with:
          version: "10.30.2"
      - uses: actions/setup-node@6044e13b5dc448c55e2357c09f80417699197238 # v6
        with:
          node-version: 22.22.0
          cache: "pnpm"
      - run: pnpm install --frozen-lockfile
      - run: pnpm turbo run build-storybook --filter=@frey-ui/storybook
      - run: test -f apps/storybook/storybook-static/preview-stats.json
      - uses: chromaui/action@5ec258af08deb3e8c36653bd618cb7fe52090031 # v15.2.0
        with:
          projectToken: ${{ secrets.CHROMATIC_PROJECT_TOKEN }}
          token: ${{ secrets.GITHUB_TOKEN }}
          workingDir: apps/storybook
          storybookBuildDir: storybook-static
          onlyChanged: true
</file>

