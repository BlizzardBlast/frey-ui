  onClick?: React.MouseEventHandler<HTMLElement>;
};

const meta: Meta<ChipStoryProps> = {
  component: Chip,
  parameters: {
    layout: 'centered'
  },
  argTypes: {
    label: {
      control: {
        type: 'text'
      },
      description: 'The text to display in the chip'
    },
