          label='Subscribe to newsletter'
          checked={checked}
          onChange={(e) => setChecked(e.target.checked)}
        />
        <p>Checkbox is: {checked ? 'checked' : 'unchecked'}</p>
      </div>
    );
  }
} satisfies Story;

export const toggle_interaction: Story = {
