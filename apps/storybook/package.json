{
  "name": "@frey-ui/storybook",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui",
    "build": "tsc -b && storybook build --stats-json",
    "typecheck": "tsc -b",
    "lint": "biome lint src .storybook vite.config.ts vitest.setup.ts",
    "format": "biome format --write src .storybook vite.config.ts vitest.setup.ts",
    "format:check": "biome format src .storybook vite.config.ts vitest.setup.ts",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --stats-json"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "frey-ui": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "10.2.12",
    "@storybook/addon-docs": "10.2.12",
    "@storybook/addon-themes": "^10.2.12",
    "@storybook/react-vite": "10.2.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "chromatic": "^15.2.0",
    "jsdom": "^28.1.0",
    "storybook": "10.2.12",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
