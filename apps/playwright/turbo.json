{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "extends": false
    },
    "dev": {
      "extends": false
    },
    "test": {
      "extends": false
    },
    "typecheck": {
      "extends": false
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", "!README.md", "!CHANGELOG.md"],
      "passThroughEnv": ["PLAYWRIGHT_*"],
      "outputs": ["playwright-report/**", "test-results/**"]
    }
  }
}
