{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "outputs": ["node_modules/.tmp/*.tsbuildinfo"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "test:coverage": {
      "inputs": ["$TURBO_DEFAULT$", "!README.md", "!CHANGELOG.md"],
      "outputs": ["coverage/**", "test-report.junit.xml"]
    }
  }
}
